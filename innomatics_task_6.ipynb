# Problem Statement 1: Smart Parking Lot Management System
def manage_parking(capacity, logs):
    current_parked = 0
    for action in logs:
        if action == "IN":
            current_parked += 1
        elif action == "OUT":
            current_parked -= 1
    status = "Available"
    if current_parked >= capacity:
        status = "Full"
    elif current_parked >= capacity * 0.9:
        status = "Almost Full"
    print(f"Currently Parked Vehicles: {current_parked}")
    print(f"Parking Status: {status}")
manage_parking(50, ["IN", "IN", "IN", "OUT", "IN", "IN", "OUT"])


# Problem Statement 2: Online Food Delivery Time Estimator
def estimate_delivery(distance_km, traffic, weather):
    base_time = distance_km * 5
    traffic_delays = {"Low": 0, "Medium": 10, "High": 15}
    weather_delays = {"Clear": 0, "Rainy": 10, "Stormy": 20}
    total_eta = base_time + traffic_delays.get(traffic, 0) + weather_delays.get(weather, 0)
    print(f"Estimated Delivery Time: {total_eta} minutes")
estimate_delivery(8, "High", "Rainy")


# Problem Statement 3: Movie Theatre Seat Occupancy Analyzer
def analyze_occupancy(total_seats, booked_seats_list):
    booked_count = len(booked_seats_list)
    occupancy_pct = (booked_count / total_seats) * 100
    status = "Seats Available"
    if occupancy_pct == 100:
        status = "Housefull"
    elif occupancy_pct >= 75:
        status = "Almost Full"
    print(f"Occupancy: {occupancy_pct:.0f}%")
    print(f"Show Status: {status}")
analyze_occupancy(200, [1] * 150)


# Problem Statement 4: Cloud Server Load Classification System
def classify_server_load(readings):
    avg_load = sum(readings) / len(readings)
    status = "Normal"
    if avg_load >= 80:
        status = "Critical"
    elif avg_load >= 50:
        status = "Warning"
    print(f"Average CPU Load: {avg_load:.0f}%")
    print(f"Server Status: {status}")
classify_server_load([45, 60, 70, 85, 90])


# Problem Statement 5: Smart Classroom Resource Usage Monitor
def monitor_resources(usage_dict):
    threshold = 8
    overused = [res for res, hours in usage_dict.items() if hours > threshold]
    print(f"Overused Resources: {', '.join(overused) if overused else 'None'}")
    print(f"Energy Alert: {'Yes' if overused else 'No'}")
monitor_resources({"Projector": 6, "AC": 9, "Lights": 4})


# Problem Statement 6: Online Event Registration Capacity Controller
def manage_registration(capacity, total_registrations):
    confirmed = min(total_registrations, capacity)
    waitlisted = max(0, total_registrations - capacity)
    status = "Closed" if total_registrations >= capacity else "Open"
    print(f"Confirmed Registrations: {confirmed}")
    print(f"Waitlisted Users: {waitlisted}")
    print(f"Registration Status: {status}")
manage_registration(100, 105)