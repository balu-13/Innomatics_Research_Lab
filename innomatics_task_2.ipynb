# Problem 1: Unique Words in a Sentence
sentence="python is easy and python is powerful"
words=sentence.split()
unique_words=set(words)
print(f"Unique words count: {len(unique_words)}")
print(f"Unique words: {unique_words}")

# Problem 2: Highest Salary from Employee Data
employees={"Ravi":75000,"Anita":68000,"Kiran":72000}
max_emp=max(employees,key=employees.get)
print(f"Highest Salary: {max_emp} - {employees[max_emp]}")

# Problem 3: Find Maximum and Minimum Values
numbers=[45,22,89,10,66]
print(f"List: {numbers}")
print(f"Max: {max(numbers)}")
print(f"Min: {min(numbers)}")

# Problem 4: Count Products Above a Price Threshold
prices=[450,1200,899,1500,300]
count=len([p for p in prices if p>1000])
print(f"Products above 1000: {count}")

# Problem 5: Calculate Attendance Percentage
attendance=["P","P","A","P","P"]
p_count=attendance.count("P")
percentage=(p_count/len(attendance))*100
print(f"Attendance Percentage: {percentage}")

# Problem 6: Remove Duplicate Phone Numbers
phone_numbers=[9876543210,9123456789,9876543210]
unique_phones=set(phone_numbers)
print(f"Unique phone numbers: {unique_phones}")

# Problem 7: Count Character Frequency
text="pythonp"
freq={}
for char in text:
    freq[char]=freq.get(char,0)+1
print(freq)

# Problem 8: Convert List to Tuple
data_list=[10,20,30]
data_tuple=tuple(data_list)
print(f"Tuple: {data_tuple}")

# Problem 9: Check if a Key Exists in a Dictionary
emp_data={"id":101,"name":"John"}
if "name" in emp_data:
    print("Employee exists")

# Problem 10: Calculate Average Marks
marks=[70,80,60,80]
avg=sum(marks)/len(marks)
print(f"Average Marks: {avg}")