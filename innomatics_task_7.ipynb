# Problem 1: Smart Light Controller
class SmartLight:
    def __init__(self, name):
        self.name = name
    def set_status(self, action):
        # Displays the name and the requested status (ON/OFF)
        print(f"{self.name} is {action}")
light = SmartLight("Bedroom Light")
light.set_status("ON")


# Problem 2: Employee ID Card System
class Employee:
    def __init__(self, name, emp_id, department):
        self.name = name
        self.emp_id = emp_id
        self.department = department
    def display_card(self):
        # Prints a formatted ID card summary
        print("Employee ID Card")
        print(f"Name: {self.name}")
        print(f"ID: {self.emp_id}")
        print(f"Department: {self.department}")
emp = Employee("Rahul", "EMP102", "IT")
emp.display_card()


# Problem 3: Mobile Contact Record
class Contact:
    def __init__(self, name, phone):
        self.name = name
        self.phone = phone
    def display_contact(self):
        # Confirms saving and shows contact details
        print("Contact Saved")
        print(f"Name: {self.name}")
        print(f"Phone: {self.phone}")
person = Contact("Anita", "9876543210")
person.display_contact()


# Problem 4: Product Price Tag Generator
class Product:
    def __init__(self, name, price):
        self.name = name
        self.price = price
    def print_tag(self):
        # Formats the price with the Rupee symbol
        print(f"Product: {self.name}")
        print(f"Price: ₹{self.price}")
item = Product("Headphones", 2499)
item.print_tag()


# Problem 5: Movie Rating Display System
class Movie:
    def __init__(self, name, rating):
        self.name = name
        self.rating = rating
    def show_details(self):
        # Displays movie name and rating out of 5
        print(f"Movie: {self.name}")
        print(f"Rating: {self.rating} / 5")
film = Movie("Inception", 4.8)
film.show_details()


# Problem 6: Delivery Address Manager
class Delivery:
    def __init__(self, customer, address):
        self.customer = customer
        self.address = address
    def print_details(self):
        # Outputs a summary for logistics/courier use
        print("Delivery Details")
        print(f"Customer: {self.customer}")
        print(f"Address: {self.address}")
order = Delivery("Suman", "Hyderabad")
order.print_details()