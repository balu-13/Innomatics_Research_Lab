#Problem 1: Employee Performance Bonus Eligibility
employees = {
    "Ravi": 92,
    "Anita": 88,
    "Kiran": 92,
    "Suresh": 85
}
# 1. Identify the highest score using the max() function on dictionary values
max_score = max(employees.values())
# 2. Use a list comprehension to find all employees who have this max score
top_performers = [name for name, score in employees.items() if score == max_score]
# 3. Format the output string
names_str = ", ".join(top_performers)
print(f"Top Performers Eligible for Bonus: {names_str} (Score: {max_score})")


#Problem 2: Search Query Keyword Analysis
query = "Buy mobile phone buy phone online"
# 1. Normalize: convert to lowercase and split into a list of words
words = query.lower().split()
# 2. Count frequencies using a dictionary
freq_map = {}
for word in words:
    freq_map[word] = freq_map.get(word, 0) + 1
# 3. Filter: Keep only those with frequency > 1
duplicates = {word: count for word, count in freq_map.items() if count > 1}
print(duplicates)

#Problem 3: Sensor Data Validation
sensor_readings = [3, 4, 7, 8, 10, 12, 5]
# 1. Iterate with index (hour) and value (reading)
# 2. Filter for even numbers (reading % 2 == 0)
valid_readings = [(hour, val) for hour, val in enumerate(sensor_readings) if val % 2 == 0]
print("Valid Sensor Readings (Hour, Value):")
print(valid_readings)

#Problem 4: Email Domain Usage Analysis
emails = [
    "ravi@gmail.com",
    "anita@yahoo.com",
    "kiran@gmail.com",
    "suresh@gmail.com",
    "meena@yahoo.com"
]
# 1. Extract domains (everything after '@')
domains = [email.split('@')[1] for email in emails]
# 2. Count occurrences of each domain
domain_counts = {}
for d in domains:
    domain_counts[d] = domain_counts.get(d, 0) + 1
# 3. Calculate and display percentage
total_emails = len(emails)
for domain, count in domain_counts.items():
    percentage = (count / total_emails) * 100
    print(f"{domain}: {percentage:.0f}%")


#Problem 5: Sales Spike Detection
sales = [1200, 1500, 900, 2200, 1400, 3000]
# 1. Calculate the average sales
avg_sales = sum(sales)/len(sales)
# 2. Define the spike threshold (30% above average)
threshold = avg_sales * 1.30
# 3. Loop through sales and check against threshold
# Note: Day number is index + 1
for i, sale in enumerate(sales):
    if sale > threshold:
        print(f"Day {i + 1}: {sale}")

#Problem 6: Duplicate User ID Detection
user_ids = ["user1", "user2", "user1", "user3", "user1", "user3"]
# 1. Count occurrences of all IDs
id_counts = {}
for uid in user_ids:
    id_counts[uid] = id_counts.get(uid, 0) + 1
# 2. Identify and display only duplicates (count > 1)
for uid, count in id_counts.items():
    if count > 1:
        print(f"{uid} → {count} times")

